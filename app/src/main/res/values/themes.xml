<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.FootMash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent_blue</item>
        
        <!-- Tamna tema iz Behance dizajna -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        
        <!-- Custom text appearance za moderni look -->
        <item name="textAppearanceHeadline1">@style/TextAppearance.FootMash.Headline1</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.FootMash.Headline2</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.FootMash.Headline3</item>
        <item name="textAppearanceHeadline4">@style/TextAppearance.FootMash.Headline4</item>
        <item name="textAppearanceHeadline5">@style/TextAppearance.FootMash.Headline5</item>
        <item name="textAppearanceHeadline6">@style/TextAppearance.FootMash.Headline6</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.FootMash.Subtitle1</item>
        <item name="textAppearanceSubtitle2">@style/TextAppearance.FootMash.Subtitle2</item>
        <item name="textAppearanceBody1">@style/TextAppearance.FootMash.Body1</item>
        <item name="textAppearanceBody2">@style/TextAppearance.FootMash.Body2</item>
    </style>

    <!-- Obla Card kartica (Behance stil) -->
    <style name="FootMashCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <!-- Match Card (Plava pozadina) -->
    <style name="MatchCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">32dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/accent_blue_dark</item>
    </style>

    <!-- Pill gumb -->
    <style name="PillButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">24dp</item>
        <item name="backgroundTint">@color/surface</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:paddingHorizontal">16dp</item>
    </style>

    <style name="PillButton.Active" parent="PillButton">
        <item name="backgroundTint">@color/accent_blue</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Tipografija (Moderni zaobljeni izgled) -->
    <style name="TextAppearance.FootMash.Headline1" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.FootMash.Headline2" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.FootMash.Headline3" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.FootMash.Headline4" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.FootMash.Headline5" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
    </style>
    <style name="TextAppearance.FootMash.Headline6" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
    </style>
    <style name="TextAppearance.FootMash.Subtitle1" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="TextAppearance.FootMash.Subtitle2" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="TextAppearance.FootMash.Body1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="TextAppearance.FootMash.Body2" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>